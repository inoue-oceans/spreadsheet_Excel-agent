# このファイルは Streamlit Community Cloud の Secrets 設定画面にコピペするためのテンプレート
# 実ファイル (.streamlit/secrets.toml) は .gitignore 対象

[auth]
redirect_uri = 'https://YOUR-APP-URL.streamlit.app/oauth2callback'
cookie_secret = 'GENERATE_RANDOM_STRING_32_CHARS_OR_MORE'

[auth.google]
client_id = 'YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com'
client_secret = 'YOUR_GOOGLE_OAUTH_CLIENT_SECRET'
server_metadata_url = 'https://accounts.google.com/.well-known/openid-configuration'

# Google Sheets API 用の OAuth 設定（SSO と同じ Client ID を使い回してOK）
# Google Cloud Console の承認済みリダイレクト URI に redirect_uri を登録しておくこと
[google_sheets_oauth]
client_id = 'YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com'
client_secret = 'YOUR_GOOGLE_OAUTH_CLIENT_SECRET'
redirect_uri = 'https://YOUR-APP-URL.streamlit.app/'
